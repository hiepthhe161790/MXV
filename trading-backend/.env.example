# Environment Configuration - Development

# Node.js
NODE_ENV=development
PORT=3001

# MongoDB
MONGODB_URL=mongodb://localhost:27017/trading_exchange

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Logging
LOG_LEVEL=info

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d

# Risk Rules (Optional - override defaults)
MAX_LEVERAGE=10
MIN_MARGIN_REQUIREMENT=0.10
MAX_EXPOSURE_PER_ACCOUNT=100000
MARGIN_CALL_THRESHOLD=0.20
LIQUIDATION_THRESHOLD=0.05

# API Settings
API_RATE_LIMIT=1000
API_TIMEOUT=30000

# PhuQuy API Integration Settings
PHUQUY_BASE_URL=https://portal.phuquygroup.vn:6868
PHUQUY_USERNAME=your_username
PHUQUY_PASSWORD=your_password
PHUQUY_CLIENT_CODE=your_client_code
PHUQUY_CHECKSUM=your_checksum
PHUQUY_MOCK_MODE=true

