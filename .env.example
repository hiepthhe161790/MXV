# Trading System Environment Variables

# Node Environment
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/mvx_trading
DB_NAME=mvx_trading
DB_USER=
DB_PASSWORD=

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=24h

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=debug

# API Configuration
API_VERSION=v1
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Exchange Integration
EXCHANGE_API_URL=https://api-trading.mxv.vn
EXCHANGE_API_KEY=your_exchange_api_key
EXCHANGE_API_SECRET=your_exchange_api_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# SMS Configuration
SMS_API_KEY=
SMS_API_URL=

# Margin Configuration
MARGIN_INITIAL_RATIO=0.10
MARGIN_MAINTENANCE_RATIO=0.075
MARGIN_CALL_THRESHOLD=0.5
LIQUIDATION_THRESHOLD=0.3

# Settlement Configuration
SETTLEMENT_TIME=15:30
SETTLEMENT_TIMEZONE=Asia/Ho_Chi_Minh

# Audit Configuration
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOG_ARCHIVE=true

# Feature Flags
ENABLE_TWO_FACTOR=false
ENABLE_AUTO_LIQUIDATION=true
ENABLE_MARGIN_CALLS=true
ENABLE_PRICE_ALERTS=true

# Admin Configuration
ADMIN_EMAIL=admin@mvx.vn
ADMIN_PHONE=+84-xxx-xxxx-xx
